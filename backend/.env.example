# =====================================================================
# GestionPro — backend environment variables (example)
# Copy this file to `.env` and fill in the values for your environment.
#
# IMPORTANT: Save this file as `backend/.env` (same folder as `package.json`).
# The server resolves that path from the backend package root (`__dirname`), so
# it loads even when your shell or IDE cwd is elsewhere.
#
# The file is parsed with `dotenv.parse` then merged into `process.env` with
# `override: true` so empty OS-level placeholders cannot mask values from this file.
# =====================================================================

# --- Core ----------------------------------------------------------------
DATABASE_URL="mysql://root:@localhost:3306/gestion-de-projet"
JWT_SECRET="change-me-in-production"
PORT=5000
# Origines autorisées en production (CORS). Virgule pour plusieurs. En dev, toutes origines autorisées.
FRONTEND_URL="http://localhost:5173"
APP_NAME="platform"
APP_DOMAIN="platform.local"

# =====================================================================
# Email provider — REQUIRED for the invitation workflow
# =====================================================================
# Without one of the providers below, the Inviter page will refuse to
# send invitations and shows a clear setup error in the UI.

# --- 1. RECOMMENDED: Brevo (Sendinblue) HTTP API ------------------------
# Free tier: 300 emails/day, no SMTP setup, great deliverability.
#   - Create an account     : https://www.brevo.com
#   - Generate an API key   : Account > SMTP & API > API Keys
#   - Verify your sender    : Senders & IP > Senders (single email or
#                              full domain authentication)
# Then set:
#   BREVO_API_KEY=xkeysib-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
#   EMAIL_FROM="GestionPro <no-reply@yourdomain.com>"
BREVO_API_KEY=xkeysib-your-brevo-api-key-here
EMAIL_FROM="GestionPro <no-reply@yourdomain.com>"
EMAIL_REPLY_TO=
# Optional: HTTP timeout (ms) for Brevo API calls — default 25000 (25s). Clamp: 3000–120000.
BREVO_API_TIMEOUT_MS=

# --- 2. ALTERNATIVE: SMTP relay -----------------------------------------
# Used automatically when BREVO_API_KEY is empty. Works with any SMTP
# provider (Gmail, SES, Mailgun, Postmark, Mailtrap, ...).
#
# Gmail example (the password MUST be a Google App Password, NOT your
# normal Gmail password — Account > Security > 2-Step Verification >
# App passwords):
#   SMTP_HOST=smtp.gmail.com
#   SMTP_PORT=587
#   SMTP_SECURE=false
#   SMTP_USER=your-account@gmail.com
#   SMTP_PASS=your-gmail-app-password
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
# Optional. If empty, falls back to EMAIL_FROM, then to "GestionPro <SMTP_USER>".
SMTP_FROM=
SMTP_REPLY_TO=

# --- AI — task assistant (Demander à l'IA) ---------------------------------
# Use either Groq (free tier) or OpenAI. Keys stay server-side only.
# Groq: https://console.groq.com
GROQ_API_KEY=your_free_key_here
# OpenAI (optional): https://platform.openai.com
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# --- Member calendar integrations (Google / Outlook) ----------------------
# Create OAuth apps and set redirect URIs to:
#   http://localhost:5000/api/calendar/google/callback
#   http://localhost:5000/api/calendar/outlook/callback
GOOGLE_CALENDAR_CLIENT_ID=
GOOGLE_CALENDAR_CLIENT_SECRET=
GOOGLE_CALENDAR_REDIRECT_URI=
MICROSOFT_CALENDAR_CLIENT_ID=
MICROSOFT_CALENDAR_CLIENT_SECRET=
MICROSOFT_CALENDAR_TENANT_ID=common
MICROSOFT_CALENDAR_REDIRECT_URI=
# Optional public API base (defaults to http://127.0.0.1:PORT)
API_PUBLIC_URL=
